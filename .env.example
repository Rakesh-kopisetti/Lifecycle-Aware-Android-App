# .env.example
# This project does not require specific environment variables for its core functionality.
# However, you must include this file in your submission.
# If you add any environment-dependent configurations, document them here.

# Example:
# API_BASE_URL=https://api.example.com
# FEATURE_FLAG_ENABLE_NEW_UI=true

# Database configuration (using default SQLite, no external DB required)
# DB_NAME=app.db

# Foreground service configuration
# SERVICE_NOTIFICATION_CHANNEL_ID=foreground_service_channel
# SERVICE_NAME=LifecycleMasterForegroundService

# WorkManager task intervals (in minutes)
# SYNC_TASK_INTERVAL=15
# CLEANUP_TASK_INTERVAL=1440
# HEALTH_CHECK_INTERVAL=30

# Debug mode
# DEBUG_MODE=false
